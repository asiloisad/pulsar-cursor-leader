'atom-workspace':
  'cmdorctrl-alt-insert'   : 'cursor-leader:power-global'

'atom-text-editor':
  'cmdorctrl-shift-alt-insert': 'cursor-leader:power-editor'
  'cmdorctrl-alt-pageup'   : 'cursor-leader:previous'
  'cmdorctrl-alt-pagedown' : 'cursor-leader:next'
  'cmdorctrl-alt-enter'    : 'cursor-leader:toggle'
  'cmdorctrl-alt-up'       : 'cursor-leader:move-up'
  'cmdorctrl-alt-down'     : 'cursor-leader:move-down'
  'cmdorctrl-alt-left'     : 'cursor-leader:move-left'
  'cmdorctrl-alt-right'    : 'cursor-leader:move-right'
